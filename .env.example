# ============================================================
# VibeOS — Shared Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ----- Supabase -----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ----- Google Cloud -----
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1
CLOUD_RUN_GATEWAY_URL=https://your-fastapi-gateway.run.app

# ----- Private AI (Qwen2.5-VL-7B-Instruct via vLLM on Cloud Run) -----
QWEN_ENDPOINT_URL=https://your-qwen-vllm-service.run.app/v1
QWEN_MODEL_NAME=RedHatAI/Qwen2.5-VL-7B-Instruct-quantized.w8a8

# ----- Gmail OAuth (for Email Proxy) -----
GMAIL_CLIENT_ID=your-gmail-oauth-client-id
GMAIL_CLIENT_SECRET=your-gmail-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token

# ----- Feed APIs -----
TICKETMASTER_API_KEY=your-ticketmaster-api-key
