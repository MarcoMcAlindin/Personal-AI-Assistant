# VibeOS Cloud Backend — Environment Variables
# Copy to .env and fill in your values.

# ----- Supabase (Service Role — full access) -----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ----- Private AI (Qwen2.5-VL-7B-Instruct via vLLM) -----
QWEN_ENDPOINT_URL=https://your-qwen-vllm-service.run.app/v1
QWEN_MODEL_NAME=RedHatAI/Qwen2.5-VL-7B-Instruct-quantized.w8a8

# ----- Gmail OAuth -----
GMAIL_CLIENT_ID=your-gmail-oauth-client-id
GMAIL_CLIENT_SECRET=your-gmail-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token

# ----- Feed APIs -----
TICKETMASTER_API_KEY=your-ticketmaster-api-key

# ----- Server Config -----
PORT=8080
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
