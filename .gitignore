# ========================
# VibeOS Root .gitignore
# ========================

# ----- Environment & Secrets -----
.env
.env.local
.env.*.local
*.pem
*.key

# ----- OS Artifacts -----
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ----- IDEs -----
.idea/
.vscode/
*.code-workspace
*.iml

# ----- Node (Web & Mobile) -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
build/
.cache/

# ----- Python (Cloud Backend) -----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
*.whl
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
.coverage.*

# ----- Docker -----
*.log

# ----- Expo / React Native -----
.expo/
*.jks
*.p8
*.p12
*.mobileprovision

# ----- Misc -----
*.bak
*.tmp
